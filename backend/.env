# Приложение
APP_NAME=RoadMate API
DEBUG=True

# JWT (твои настройки)
JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# База данных
USE_POSTGRESQL=True
# Формат: postgresql+asyncpg://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roadmate_db